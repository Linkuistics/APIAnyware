framework LinkPresentation {
    class LPMetadataProvider {
        method startFetchingMetadataForRequest:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method startFetchingMetadataForURL:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 2
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
