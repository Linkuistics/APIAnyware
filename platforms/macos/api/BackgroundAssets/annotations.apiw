        }
        method checkForUpdatesWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
        method contentsAtPath:searchingInAssetPackWithIdentifier:options:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method ensureLocalAvailabilityOfAssetPack:completionHandler: is-instance=#true {
