            source llm
        }
        method getAllAssetPacksWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
        method getAssetPackWithIdentifier:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method getLocalStatusOfAssetPackWithIdentifier:completionHandler: is-instance=#true {
