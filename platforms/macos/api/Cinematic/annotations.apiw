framework Cinematic {
    class CNAssetInfo {
        method checkIfCinematic:completionHandler: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
        method loadFromAsset:completionHandler: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    class CNAssetSpatialAudioInfo {
        method "checkIfContainsSpatialAudio(asset:completionHandler:)" is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
        method checkIfContainsSpatialAudio:completionHandler: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
        method loadFromAsset:completionHandler: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    class CNCompositionInfo {
        method checkIfCinematic:completionHandler: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
        method insertTimeRange:ofCinematicAssetInfo:atTime:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method loadFromAsset:completionHandler: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    class CNRenderingSessionAttributes {
        method loadFromAsset:completionHandler: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    class CNScript {
        method loadFromAsset:changes:progress:completionHandler: is-instance=#false {
            block-param 3 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 9
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 1
    }
}
