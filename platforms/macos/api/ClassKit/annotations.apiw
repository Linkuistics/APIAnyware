framework ClassKit {
    class CLSContext {
        method descendantMatchingIdentifierPath:completion: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    class CLSDataStore {
        method saveWithCompletion: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
        method contextsMatchingPredicate:completion: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method contextsMatchingIdentifierPath:completion: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method fetchActivityForURL:completion: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method checkIsAssignedDocument:completion: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 6
        block-stored 0
        parameter-ownership 1
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
