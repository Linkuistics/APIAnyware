framework AVKit {
    class AVCaptureView {
        method setDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
    }
    class AVPlayerView {
        method setDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method beginTrimmingWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            threading main_thread_only
            source llm
        }
        method setPictureInPictureDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
    }
    class AVRoutePickerView {
        method setDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 1
        block-stored 0
        parameter-ownership 7
        threading-main-thread-only 5
        threading-any-thread 0
        error-pattern 0
    }
}
