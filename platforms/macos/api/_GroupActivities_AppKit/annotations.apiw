framework _GroupActivities_AppKit {
    class GroupActivitySharingController {
        method commitEditingAndReturnError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method "init(preparationHandler:)" is-instance=#true {
            block-param 0 invocation=stored
            threading main_thread_only
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 0
        block-stored 1
        parameter-ownership 0
        threading-main-thread-only 3
        threading-any-thread 0
        error-pattern 1
    }
}
