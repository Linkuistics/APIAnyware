framework DeviceCheck {
    class DCAppAttestService {
        method attestKey:clientDataHash:completionHandler: is-instance=#true {
            block-param 2 invocation=async_copied
            source llm
        }
        method generateAssertion:clientDataHash:completionHandler: is-instance=#true {
            block-param 2 invocation=async_copied
            source llm
        }
        method generateKeyWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
    }
    class DCDevice {
        method generateTokenWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 4
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
