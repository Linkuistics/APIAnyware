framework SafetyKit {
    class SACrashDetectionManager {
        method requestAuthorizationWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
    }
    class SAEmergencyResponseManager {
        method dialVoiceCallToPhoneNumber:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 2
        block-stored 0
        parameter-ownership 2
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
