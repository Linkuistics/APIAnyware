framework MultipeerConnectivity {
    class MCAdvertiserAssistant {
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
    }
    class MCBrowserViewController {
        method commitEditingAndReturnError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            threading main_thread_only
            source llm
        }
    }
    class MCNearbyServiceAdvertiser {
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
    }
    class MCNearbyServiceBrowser {
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
    }
    class MCSession {
        method sendData:toPeers:withMode:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method sendResourceAtURL:withName:toPeer:withCompletionHandler: is-instance=#true {
            block-param 3 invocation=async_copied
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
        method startStreamWithName:toPeer:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method nearbyConnectionDataForPeer:withCompletionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 2
        block-stored 0
        parameter-ownership 5
        threading-main-thread-only 3
        threading-any-thread 0
        error-pattern 3
    }
}
