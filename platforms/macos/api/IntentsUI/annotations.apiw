framework IntentsUI {
    class INUIAddVoiceShortcutButton {
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            threading main_thread_only
            source llm
        }
    }
    class INUIAddVoiceShortcutViewController {
        method commitEditingAndReturnError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            threading main_thread_only
            source llm
        }
    }
    class INUIEditVoiceShortcutViewController {
        method commitEditingAndReturnError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            threading main_thread_only
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 0
        block-stored 0
        parameter-ownership 3
        threading-main-thread-only 7
        threading-any-thread 0
        error-pattern 2
    }
}
