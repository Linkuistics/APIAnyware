framework Accessibility {
    class AXNumericDataAxisDescriptor {
        method "init(attributedTitle:range:gridlinePositions:valueDescriptionProvider:)" is-instance=#true {
            block-param 3 invocation=stored
            source llm
        }
        method "init(title:range:gridlinePositions:valueDescriptionProvider:)" is-instance=#true {
            block-param 3 invocation=stored
            source llm
        }
        method initWithAttributedTitle:lowerBound:upperBound:gridlinePositions:valueDescriptionProvider: is-instance=#true {
            block-param 4 invocation=stored
            source llm
        }
        method initWithTitle:lowerBound:upperBound:gridlinePositions:valueDescriptionProvider: is-instance=#true {
            block-param 4 invocation=stored
            source llm
        }
        method setValueDescriptionProvider: is-instance=#true {
            block-param 0 invocation=stored
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 0
        block-stored 5
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
