framework Intents {
    class INFocusStatusCenter {
        method requestAuthorizationWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
    }
    class INInteraction {
        method deleteAllInteractionsWithCompletion: is-instance=#false {
            block-param 0 invocation=async_copied
            source llm
        }
        method deleteInteractionsWithGroupIdentifier:completion: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
        method deleteInteractionsWithIdentifiers:completion: is-instance=#false {
            block-param 1 invocation=async_copied
            source llm
        }
        method donateInteractionWithCompletion: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
    }
    class INVoiceShortcutCenter {
        method getAllVoiceShortcutsWithCompletion: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
        method getVoiceShortcutWithIdentifier:completion: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 7
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
