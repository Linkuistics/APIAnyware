framework SharedWithYou {
    class SWCollaborationView {
        method dismissPopover: is-instance=#true {
            block-param 0 invocation=async_copied
            threading main_thread_only
            source llm
        }
        method setCloudSharingDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method setCloudSharingServiceDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method setDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
    }
    class SWHighlightCenter {
        method collaborationHighlightForIdentifier:error: is-instance=#true {
            threading any_thread
            error-pattern error_out_param
            source llm
        }
        method getCollaborationHighlightForURL:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            threading any_thread
            source llm
        }
        method getHighlightForURL:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            threading any_thread
            source llm
        }
        method getSignedIdentityProofForCollaborationHighlight:usingData:completionHandler: is-instance=#true {
            block-param 2 invocation=async_copied
            threading any_thread
            source llm
        }
        method setDelegate: is-instance=#true {
            threading any_thread
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 4
        block-stored 0
        parameter-ownership 4
        threading-main-thread-only 4
        threading-any-thread 5
        error-pattern 1
    }
}
