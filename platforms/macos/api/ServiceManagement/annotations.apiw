framework ServiceManagement {
    class SMAppService {
        method registerAndReturnError: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method unregisterAndReturnError: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method unregisterWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 1
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 2
    }
}
