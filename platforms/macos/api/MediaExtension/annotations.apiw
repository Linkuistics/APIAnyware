framework MediaExtension {
    class MEByteSource {
        method readDataOfLength:fromOffset:completionHandler: is-instance=#true {
            block-param 2 invocation=async_copied
            source llm
        }
        method readDataOfLength:fromOffset:toDestination:bytesRead:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method readDataOfLength:fromOffset:toDestination:completionHandler: is-instance=#true {
            block-param 3 invocation=async_copied
            source llm
        }
    }
    class MERAWProcessorPixelBufferManager {
        method createPixelBufferAndReturnError: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    class MEVideoDecoderPixelBufferManager {
        method createPixelBufferAndReturnError: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 2
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 3
    }
}
