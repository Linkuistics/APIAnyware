framework InputMethodKit {
    class IMKCandidates {
        method showSublist:subListDelegate: is-instance=#true {
            param-ownership 1 ownership=weak
            source llm
        }
    }
    class IMKInputController {
        method initWithServer:delegate:client: is-instance=#true {
            param-ownership 1 ownership=weak
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 0
        block-stored 0
        parameter-ownership 3
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
