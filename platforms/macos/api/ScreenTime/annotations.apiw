framework ScreenTime {
    class STWebHistory {
        method fetchAllHistoryWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            source llm
        }
        method fetchHistoryDuringInterval:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method initWithBundleIdentifier:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method initWithBundleIdentifier:profileIdentifier:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    class STWebpageController {
        method commitEditingAndReturnError: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
        method setBundleIdentifier:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 2
        block-stored 0
        parameter-ownership 1
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 4
    }
}
