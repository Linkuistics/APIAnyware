framework Social {
    class SLComposeServiceViewController {
        method commitEditingAndReturnError: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    class SLRequest {
        method performRequestWithHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            threading any_thread
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 1
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 1
        error-pattern 1
    }
}
