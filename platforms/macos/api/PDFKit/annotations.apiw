framework PDFKit {
    class PDFView {
        method setDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 0
        block-stored 0
        parameter-ownership 2
        threading-main-thread-only 1
        threading-any-thread 0
        error-pattern 0
    }
}
