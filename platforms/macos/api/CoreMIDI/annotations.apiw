        method setEnabled:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method setName:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 3
        block-stored 3
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 9
