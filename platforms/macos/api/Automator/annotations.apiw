framework Automator {
    class AMAction {
        method initWithContentsOfURL:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method runWithInput:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
