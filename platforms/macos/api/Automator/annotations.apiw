    class AMWorkflow {
        method initWithContentsOfURL:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method runWorkflowAtURL:withInput:error: is-instance=#false {
            error-pattern error_out_param
            source llm
        }
        method writeToURL:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    class AMWorkflowController {
        method commitEditingAndReturnError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            threading main_thread_only
            source llm
