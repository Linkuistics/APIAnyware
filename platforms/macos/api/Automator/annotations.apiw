    }
    class AMWorkspace {
        method runWorkflowAtPath:withInput:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 0
        block-stored 0
        parameter-ownership 1
        threading-main-thread-only 3
        threading-any-thread 0
        error-pattern 13
