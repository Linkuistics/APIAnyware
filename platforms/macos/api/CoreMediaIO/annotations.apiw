framework CoreMediaIO {
    class CMIOExtensionDevice {
        method addStream:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method removeStream:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    class CMIOExtensionProvider {
        method addDevice:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
        method removeDevice:error: is-instance=#true {
            error-pattern error_out_param
            source llm
        }
    }
    class CMIOExtensionStream {
        method consumeSampleBufferFromClient:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 1
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 4
    }
}
