framework IOBluetoothUI {
    class IOBluetoothDeviceSelectorController {
        method beginSheetModalForWindow:modalDelegate:didEndSelector:contextInfo: is-instance=#true {
            param-ownership 1 ownership=weak
            source llm
        }
    }
    class IOBluetoothObjectPushUIController {
        method beginSheetModalForWindow:modalDelegate:didEndSelector:contextInfo: is-instance=#true {
            param-ownership 1 ownership=weak
            source llm
        }
        method initObjectPushWithBluetoothDevice:withFiles:delegate: is-instance=#true {
            param-ownership 2 ownership=weak
            source llm
        }
    }
    class IOBluetoothServiceBrowserController {
        method beginSheetModalForWindow:modalDelegate:didEndSelector:contextInfo: is-instance=#true {
            param-ownership 1 ownership=weak
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 0
        block-stored 0
        parameter-ownership 4
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
