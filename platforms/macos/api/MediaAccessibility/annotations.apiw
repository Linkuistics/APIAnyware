framework MediaAccessibility {
    class MAMusicHapticsManager {
        method addStatusObserver: is-instance=#true {
            block-param 0 invocation=stored
            source llm
        }
        method checkHapticTrackAvailabilityForMediaMatchingCode:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 1
        block-stored 1
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
