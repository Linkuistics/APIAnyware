framework CoreVideo {
    class CVReadOnlyPixelBuffer {
        method "accessUnsafeRawPlaneBytes(_:)" is-instance=#true {
            block-param 0 invocation=synchronous
            source llm
        }
        method "withUnsafeBackingIOSurfaceIfPresent(_:)" is-instance=#true {
            block-param 0 invocation=synchronous
            source llm
        }
        method "withUnsafeBuffer(_:)" is-instance=#true {
            block-param 0 invocation=synchronous
            source llm
        }
    }
    subagent-report {
        block-synchronous 3
        block-async-copied 0
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
