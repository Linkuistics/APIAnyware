framework PhotosUI {
    class PHLivePhotoView {
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            source llm
        }
    }
    class PHPickerViewController {
        method commitEditingAndReturnError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method setDelegate: is-instance=#true {
            param-ownership 0 ownership=weak
            threading main_thread_only
            source llm
        }
    }
    class PHProjectExtensionContext {
        method completeRequestReturningItems:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method openURL:completionHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
        method updatedProjectInfoFromProjectInfo:completion: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 3
        block-stored 0
        parameter-ownership 2
        threading-main-thread-only 3
        threading-any-thread 0
        error-pattern 1
    }
}
