framework SecurityUI {
    class SFCertificatePresentation {
        method presentSheetInWindow:dismissHandler: is-instance=#true {
            block-param 1 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 1
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
