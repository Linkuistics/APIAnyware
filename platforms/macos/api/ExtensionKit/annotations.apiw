framework ExtensionKit {
    class EXAppExtensionBrowserViewController {
        method commitEditingAndReturnError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            threading main_thread_only
            source llm
        }
    }
    class EXHostViewController {
        method commitEditingAndReturnError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method commitEditingWithDelegate:didCommitSelector:contextInfo: is-instance=#true {
            threading main_thread_only
            source llm
        }
        method makeXPCConnectionWithError: is-instance=#true {
            threading main_thread_only
            error-pattern error_out_param
            source llm
        }
        method setDelegate: is-instance=#true {
            threading main_thread_only
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 0
        block-stored 0
        parameter-ownership 1
        threading-main-thread-only 6
        threading-any-thread 0
        error-pattern 3
    }
}
