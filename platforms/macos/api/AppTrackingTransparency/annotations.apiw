framework AppTrackingTransparency {
    class ATTrackingManager {
        method requestTrackingAuthorizationWithCompletionHandler: is-instance=#false {
            block-param 0 invocation=async_copied
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 1
        block-stored 0
        parameter-ownership 0
        threading-main-thread-only 0
        threading-any-thread 0
        error-pattern 0
    }
}
