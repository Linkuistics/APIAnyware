        method getAllTabsWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            threading main_thread_only
            source llm
        }
        method getToolbarItemWithCompletionHandler: is-instance=#true {
            block-param 0 invocation=async_copied
            threading main_thread_only
            source llm
        }
        method openTabWithURL:makeActiveIfPossible:completionHandler: is-instance=#true {
            block-param 2 invocation=async_copied
            threading main_thread_only
            source llm
        }
    }
    subagent-report {
        block-synchronous 0
        block-async-copied 24
        block-stored 0
        parameter-ownership 1
        threading-main-thread-only 24
        threading-any-thread 2
        error-pattern 1
    }
