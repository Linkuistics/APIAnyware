target/
.build/
*.swp
.DS_Store

# Generated IR checkpoints (large JSON files, reproducible from pipeline)
collection/ir/collected/
analysis/ir/resolved/
analysis/ir/annotated/
analysis/ir/enriched/

# LLM annotation pipeline intermediates: summaries are derivable from resolved IR
# via `llm-extract`. Subagent-produced `analysis/ir/llm-annotations/*.llm.json`
# files are versioned (durability: Option A — see
# `analysis/scripts/llm-annotate-orchestration.md`); regenerating them costs
# millions of tokens, while the JSON itself is <5 KB per framework.
analysis/ir/llm-summaries/

# Generated language bindings (reproducible from enriched IR).
# Racket writes to <target>/generated/. Chez writes its emitted
# framework libraries alongside the hand-written runtime/ tree, so
# everything under apianyware/ is ignored EXCEPT runtime/ (see
# docs/specs/2026-05-27-chez-target-design.md §8 for the rationale).
generation/targets/*/generated/
generation/targets/chez/apianyware/*
!generation/targets/chez/apianyware/runtime
# Gerbil's emitted framework libraries land in lib/<framework>/ (the
# `gerbil-bindings` package root); the hand-written runtime/ + the static
# gerbil.pkg live in the same package and are committed. See
# docs/specs/2026-06-03-gerbil-target-design.md §8 (refined at leaf 050/010:
# package root is lib/, runtime at lib/runtime/, forced by the emitter's
# hardcoded :gerbil-bindings/<fw>/<cls> + :gerbil-bindings/runtime/objc imports).
generation/targets/gerbil/lib/*
!generation/targets/gerbil/lib/runtime
!generation/targets/gerbil/lib/gerbil.pkg

# Generated typed native dispatch table (ADR-0013): one @_cdecl objc_msgSend
# entry per ABI signature, emitted into the APIAnywareRacket Swift target by
# `apianyware-macos-generate` and compiled by `swift build`. Like the .rkt
# bindings it is reproducible from the IR (build order: generate -> swift build).
swift/Sources/APIAnywareRacket/Generated/

# Racket bytecode caches
generation/targets/*/runtime/compiled/
generation/targets/*/apianyware/runtime/compiled/
generation/targets/*/apps/*/compiled/

# Built sample-app .app bundles (regenerable via bundle-racket)
generation/targets/*/apps/*/build/

# AppSpec runner artifacts captured per-app (regenerable from runner output)
docs/apps/*/artifacts/

# Claude Code scheduled-task lock file (per-session tooling state)
.claude/scheduled_tasks.lock
spike-scratch/
/.grove-meta
