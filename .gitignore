target/
.build/
*.swp
.DS_Store

# Generated IR checkpoints (large JSON files, reproducible from pipeline)
collection/ir/collected/
analysis/ir/resolved/
analysis/ir/annotated/
analysis/ir/enriched/

# LLM annotation pipeline intermediates: summaries are derivable from resolved IR
# via `llm-extract`. Subagent-produced `platforms/macos/api/_llm-annotations/*.llm.json`
# files are versioned (durability: Option A — see
# `platforms/macos/tools/scripts/llm-annotate-orchestration.md`); regenerating them
# costs millions of tokens, while the JSON itself is <5 KB per framework.
analysis/ir/llm-summaries/

# Generated language bindings (reproducible from enriched IR), emitted under each
# target's §18 bindings/macos/ home. racket/sbcl/gerbil emit per-framework source
# into bindings/macos/generated/<framework>/; chez into
# bindings/macos/apianyware/<framework>/. Each target's bindings/macos/README.md
# documents its layout.
targets/*/bindings/macos/generated/*
# racket keeps a tracked placeholder README in its (otherwise emitted) generated/.
!targets/racket/bindings/macos/generated/README.md
# gerbil's package root IS generated/ (move-gerbil-material-k13): the hand-written
# runtime/ + the static gerbil.pkg are committed beside the emitted <framework>/ dirs.
!targets/gerbil/bindings/macos/generated/runtime
!targets/gerbil/bindings/macos/generated/gerbil.pkg
# chez interleaves emitted framework libraries with the hand-written runtime/ under
# one apianyware/ package-root namespace tree (move-chez-material-k12), so everything
# under apianyware/ is ignored EXCEPT runtime/.
targets/chez/bindings/macos/apianyware/*
!targets/chez/bindings/macos/apianyware/runtime

# Generated typed native dispatch table (ADR-0013) + Swift-native trampolines
# (ADR-0027/0029/0038): one @_cdecl per ABI signature / residual decl, emitted by
# `apianyware-generate` into each target's adapter sources and compiled by that
# target's own `swift build` (targets/<t>/adapters/macos/Package.swift). Reproducible
# from the IR (build order: generate -> swift build).
targets/racket/adapters/macos/sources/Generated/
targets/chez/adapters/macos/sources/Generated/
targets/gerbil/adapters/macos/sources/Generated/
targets/sbcl/adapters/macos/sources/Generated/

# Bytecode / fasl caches beside each target's runtime (racket raco make, etc.).
targets/*/bindings/macos/runtime/compiled/
targets/chez/bindings/macos/apianyware/runtime/compiled/
targets/gerbil/bindings/macos/generated/runtime/compiled/

# Sample-app bytecode caches + built .app bundles (regenerable via bundle-<t>).
targets/*/app-implementations/macos/*/compiled/
targets/*/app-implementations/macos/*/build/

# AppSpec runner artifacts captured per-app (regenerable from runner output)
apps/macos/*/docs/artifacts/

# Claude Code scheduled-task lock file (per-session tooling state)
.claude/scheduled_tasks.lock
spike-scratch/
/.grove-meta
/.grove-worktrees
